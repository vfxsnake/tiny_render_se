{
    "version": 4,
    "configurations": [
        {
            "name": "WSL-GCC",
            "includePath": [
                "${workspaceFolder}/**"
            ],
            "defines": [
                "VULKAN_HPP_NO_CONSTRUCTORS"
            ],
            "compilerPath": "/usr/bin/g++",
            "cStandard": "c17",
            "cppStandard": "gnu++20",
            "intelliSenseMode": "linux-gcc-x64",
            "configurationProvider": "ms-vscode.cmake-tools",
            "compileCommands": [
                "${workspaceFolder}/build_wsl/compile_commands.json"
            ]
        }
    ]
}